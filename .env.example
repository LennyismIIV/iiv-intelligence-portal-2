# IIV Intelligence Portal - environment variables
#
# Copy this file to `.env` for local development. On Render, these are set
# automatically by render.yaml (or you can override them in the dashboard).

# Express listen port. Render sets this automatically; locally defaults to 5000.
PORT=5000

# Node environment. Use "production" for prod builds, "development" for dev.
NODE_ENV=development

# Path to the SQLite database file.
# - Local dev:   leave blank or set to "data.db" (relative to project root)
# - Render prod: set to "/data/iiv.db" so the file lives on the persistent disk
DB_PATH=data.db

# Set to "true" to enable SO_REUSEPORT on listen() (Linux only, mostly for
# multi-process setups). Leave unset on Render and most cloud hosts.
# REUSE_PORT=false
